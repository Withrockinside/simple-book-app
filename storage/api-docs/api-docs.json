{
    "openapi": "3.0.0",
    "info": {
        "title": "Simple Book App API",
        "description": "A simple CRUD API for managing a book collection",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "Main API Gateway"
        }
    ],
    "paths": {
        "/books": {
            "get": {
                "tags": [
                    "Books"
                ],
                "summary": "Get paginated list of books",
                "operationId": "getBookList",
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Book"
                                            }
                                        },
                                        "current_page": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "last_page": {
                                            "type": "integer",
                                            "example": 5
                                        },
                                        "per_page": {
                                            "type": "integer",
                                            "example": 10
                                        },
                                        "total": {
                                            "type": "integer",
                                            "example": 50
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Books"
                ],
                "summary": "Create a new book",
                "operationId": "storeBook",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BookStoreRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Book created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Book"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/books/{id}": {
            "get": {
                "tags": [
                    "Books"
                ],
                "summary": "Get a single book",
                "operationId": "getBook",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Book"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Book not found"
                    }
                }
            },
            "put": {
                "tags": [
                    "Books"
                ],
                "summary": "Update a book",
                "operationId": "updateBook",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BookUpdateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Book updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Book"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Book not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Books"
                ],
                "summary": "Delete a book",
                "operationId": "deleteBook",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Book deleted successfully"
                    },
                    "404": {
                        "description": "Book not found"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Book": {
                "required": [
                    "title",
                    "publisher",
                    "author",
                    "genre",
                    "book_publication",
                    "word_count",
                    "price_usd"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true,
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "The Witcher"
                    },
                    "publisher": {
                        "type": "string",
                        "example": "SuperNowa"
                    },
                    "author": {
                        "type": "string",
                        "example": "Andrzej Sapkowski"
                    },
                    "genre": {
                        "type": "string",
                        "example": "Fantasy"
                    },
                    "book_publication": {
                        "type": "string",
                        "format": "date",
                        "example": "1993-11-02"
                    },
                    "word_count": {
                        "type": "integer",
                        "example": 120000,
                        "minimum": 1
                    },
                    "price_usd": {
                        "type": "number",
                        "format": "float",
                        "example": 29.99,
                        "maximum": 999999.99,
                        "minimum": 0
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "deleted_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true,
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "BookStoreRequest": {
                "required": [
                    "title",
                    "publisher",
                    "author",
                    "genre",
                    "book_publication",
                    "word_count",
                    "price_usd"
                ],
                "properties": {
                    "title": {
                        "type": "string",
                        "example": "The Witcher",
                        "maxLength": 255
                    },
                    "publisher": {
                        "type": "string",
                        "example": "SuperNowa",
                        "maxLength": 255
                    },
                    "author": {
                        "type": "string",
                        "example": "Andrzej Sapkowski",
                        "maxLength": 255
                    },
                    "genre": {
                        "type": "string",
                        "example": "Fantasy",
                        "maxLength": 100
                    },
                    "book_publication": {
                        "type": "string",
                        "format": "date",
                        "example": "1993-11-02"
                    },
                    "word_count": {
                        "type": "integer",
                        "example": 120000,
                        "minimum": 1
                    },
                    "price_usd": {
                        "type": "number",
                        "format": "float",
                        "example": 29.99,
                        "maximum": 999999.99,
                        "minimum": 0
                    }
                },
                "type": "object"
            },
            "BookUpdateRequest": {
                "properties": {
                    "title": {
                        "type": "string",
                        "example": "The Witcher",
                        "maxLength": 255
                    },
                    "publisher": {
                        "type": "string",
                        "example": "SuperNowa",
                        "maxLength": 255
                    },
                    "author": {
                        "type": "string",
                        "example": "Andrzej Sapkowski",
                        "maxLength": 255
                    },
                    "genre": {
                        "type": "string",
                        "example": "Fantasy",
                        "maxLength": 100
                    },
                    "book_publication": {
                        "type": "string",
                        "format": "date",
                        "example": "1993-11-02"
                    },
                    "word_count": {
                        "type": "integer",
                        "example": 120000,
                        "minimum": 1
                    },
                    "price_usd": {
                        "type": "number",
                        "format": "float",
                        "example": 29.99,
                        "minimum": 0
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Books",
            "description": "Books"
        }
    ]
}